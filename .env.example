# Grudge WoW stack
GATEWAY_PORT=8787
PIPELINE_PORT=3000
WOW_DATA_PATH=
# Licensed 3.3.5a client MPQ folder (wowserhq/pipeline + blizzardry) — e.g. C:/Games/WoW/Data
WOW_MPQ_DATA_PATH=
WOWSER_NATIVE_PORT=3001
# Set when wowserhq/wowser native pipeline runs (server/wowser npm run serve)
WOWSER_NATIVE_URL=

# AzerothCore (Docker default ports)
WOW_AUTH_HOST=127.0.0.1:3724
WOW_WORLD_HOST=127.0.0.1:8085
WOW_REALM_NAME=Grudge WoW

# Public URLs (Cloudflare tunnel)
PUBLIC_GATEWAY_URL=https://wow-api.grudge-studio.com
PUBLIC_PIPELINE_URL=https://wow-pipeline.grudge-studio.com
PUBLIC_AUTH_WS=wss://wow-auth.grudge-studio.com
PUBLIC_WORLD_WS=wss://wow-world.grudge-studio.com
CORS_ORIGIN=https://wow.grudge-studio.com

# Grudge ID auth
GRUDGE_AUTH_URL=https://id.grudge-studio.com
REQUIRE_GRUDGE_AUTH=true

# AzerothCore SOAP (auto-provision WoW accounts from Grudge ID)
AC_SOAP_HOST=ac-worldserver:7878
AC_SOAP_USER=admin
AC_SOAP_PASS=admin

# Player profile store (grudgeUsername + wow login mapping)
PLAYER_DATA_PATH=./data/players.json

# AzerothCore Docker
DOCKER_DB_ROOT_PASSWORD=change_me
DOCKER_AUTH_EXTERNAL_PORT=3724
DOCKER_WORLD_EXTERNAL_PORT=8085
DOCKER_DB_EXTERNAL_PORT=63306
DOCKER_IMAGE_TAG=master

# Docker Hub / Build Cloud
# Org access token (dckr_oat_*): docker login -u grudgestudio
# Required OAT scopes: cloud-connect + Image Push on wow-grudge-gateway/pipeline repos
DOCKERHUB_USERNAME=grudgestudio
DOCKER_API_TOKEN_CLOUD=
DOCKER_BUILDX_BUILDER=cloud-molochdadev-grudgestudio
DOCKER_BUILD_CLOUD_ENDPOINT=molochdadev/grudgestudio
GRUDGE_WOW_IMAGE=grudgestudio/grudge_wow:latest
WOW_GATEWAY_IMAGE=grudgestudio/grudge_wow:latest
WOW_PIPELINE_IMAGE=grudgestudio/grudge_wow:latest

# Gemini CLI doc audits (scripts/gemini-docs.ps1) — create key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cloudflare API (scripts/verify-credentials.ps1) — needs Account + Zone Read + DNS Read + Tunnel Read
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# Local tunnel credentials for docker-compose.hub.yml cloudflared-wow (path to the *.json from "cloudflared tunnel create")
# If using token: set CLOUDFLARE_TUNNEL_TOKEN_WOW and edit cloudflared service command in compose
CLOUDFLARE_TUNNEL_CRED_FILE=/mnt/c/Users/david/.cloudflared/40054045-d722-400d-811e-ac8bcff05d68.json
# On grudgestudio: use Windows cloudflared + cloudflared/config.yml (WOW_USE_DOCKER_TUNNEL=0).
# Docker tunnel is opt-in: docker compose -f docker-compose.hub.yml --profile tunnel up -d
WOW_USE_DOCKER_TUNNEL=0

# Grudge ecosystem integrations (optional for wow-grudge-studio)
POLY_PIZZA_KEY=
COLYEUS_DEPLOY_TOKEN=